{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smart-campus.local/schemas/hostels.schema.json",
  "title": "Smart Campus Hostels",
  "description": "Schema for hostel allocation master data plus pending and processed applications.",
  "type": "object",
  "required": ["hostels"],
  "additionalProperties": true,
  "properties": {
    "hostels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "allocationGroup", "capacity"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Official hostel/residence name."
          },
          "code": {
            "type": ["string", "null"],
            "description": "Residence code, if assigned."
          },
          "unitRange": {
            "type": ["string", "null"],
            "description": "Block/floor range where applicable (e.g. '0-14')."
          },
          "allocationGroup": {
            "type": "string",
            "enum": [
              "Males First Entering",
              "Females First Entering",
              "Males Undergraduates",
              "Undergraduates - Mixed",
              "Males Undergraduates - Disability",
              "Females Undergraduates",
              "Females Undergraduates - Disability",
              "Mix Honours Postgraduates",
              "Mix Masters and PhD"
            ]
          },
          "capacity": {
            "type": "integer",
            "minimum": 0,
            "description": "Maximum number of students that can live in this hostel."
          },
          "occupants": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Student numbers currently allocated to this hostel."
          }
        }
      }
    },
    "applications": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Pending hostel applications waiting for an admin decision."
    },
    "history": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Approved or rejected applications kept for the audit trail."
    }
  }
}
